# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (Recommended for production)
DATABASE_URL=postgresql://pentamo:pentamo_secure_password_change_me@localhost:5432/pentamo

# SQLite (Development/Testing)
# DATABASE_URL=sqlite:///./pentamo.db

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Redis Connection
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AUTHENTICATION & SECURITY (Phase 3.1)
# =============================================================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32

# Token expiry times (seconds)
JWT_ACCESS_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=2592000

# =============================================================================
# LLM MODEL CONFIGURATION
# =============================================================================

# Ollama (Model A - Chat)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2:7b

# llama.cpp Server (Model B - Tool Calling)
LLAMA_CPP_URL=http://localhost:8000

# =============================================================================
# VECTOR EMBEDDINGS & SEARCH (Phase 3.4)
# =============================================================================

# Embeddings Model
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Vector similarity threshold (0.0 - 1.0)
VECTOR_SEARCH_THRESHOLD=0.5

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend Server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend API Base URL (for Streamlit)
API_BASE_URL=http://localhost:8000

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# =============================================================================
# FRONTEND (STREAMLIT) CONFIGURATION
# =============================================================================

# Streamlit Port
STREAMLIT_PORT=8501

# Admin Dashboard
ADMIN_TITLE=PentaMo Admin
ADMIN_THEME=dark

# Chat UI
CHAT_TITLE=PentaMo Chat
CHAT_THEME=dark

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Log Level
LOG_LEVEL=INFO

# Debug Mode (false in production)
DEBUG=false

# =============================================================================
# ADMIN CREDENTIALS (Development Only)
# =============================================================================

DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=PentaMo@Admin123
DEMO_ADMIN_EMAIL=admin@pentamo.dev

DEMO_MOD_USERNAME=moderator
DEMO_MOD_PASSWORD=PentaMo@Mod456
DEMO_MOD_EMAIL=moderator@pentamo.dev

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================

# Environment
ENVIRONMENT=development

# Application Version
APP_VERSION=3.0.0
